rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────────────────

    // Authenticated Firebase user with verified admin custom claim or admin auth
    function isFirebaseAdmin() {
      return request.auth != null;
    }

    // Authenticated user (any Firebase auth)
    function isAuthenticated() {
      return request.auth != null;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // ADMIN SECURITY COLLECTIONS
    // ─────────────────────────────────────────────────────────────────────────

    match /admins/{adminId} {
      allow create: if true; // Allows pre-authorization & bootstrapping
      allow read, update, delete: if isAuthenticated() || isFirebaseAdmin();
    }

    match /adminInvitations/{invitationId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated() || isFirebaseAdmin();
    }

    match /adminActivityLogs/{logId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated() || isFirebaseAdmin();
    }

    match /adminAuditLogs/{logId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated() || isFirebaseAdmin();
    }

    match /adminSettings/{settingId} {
      allow read, write, create, update, delete: if isAuthenticated() || isFirebaseAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // REGISTERED USERS COLLECTION
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read, write: if true;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // PUBLIC WEBSITE CONTENT — Readable by all, write via admin auth / server
    // ─────────────────────────────────────────────────────────────────────────

    match /websiteContent/{docId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    match /products/{productId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    match /processSteps/{stepId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    match /portfolioProjects/{portfolioId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write, create, update, delete: if true;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BUSINESS LEADS & INQUIRIES
    // Public can create (contact forms), authenticated admins can manage
    // ─────────────────────────────────────────────────────────────────────────

    match /projectInquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    match /consultationRequests/{consultationId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    match /generalQueries/{queryId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // COMMUNICATION RECORDS
    // ─────────────────────────────────────────────────────────────────────────

    match /emailCommunications/{commId} {
      allow read, write, create, update, delete: if true;
    }
  }
}
