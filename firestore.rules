rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function adminExists() {
      return isAuthenticated()
        && (
          request.auth.token.email == 'codewithsushil7236@gmail.com'
          || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    function currentAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        ? get(/databases/$(database)/documents/admins/$(request.auth.uid)).data
        : { 'role': 'super_admin', 'status': 'active' };
    }

    function isActiveAdmin() {
      return adminExists()
        && (
          request.auth.token.email == 'codewithsushil7236@gmail.com'
          || currentAdmin().status == 'active'
        );
    }

    function isSuperAdmin() {
      return isActiveAdmin()
        && (
          request.auth.token.email == 'codewithsushil7236@gmail.com'
          || currentAdmin().role == 'super_admin'
        );
    }

    function onlyFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function noDangerousFields() {
      return !request.resource.data.keys().hasAny(['role', 'permissions', 'status', 'uid', '__proto__']);
    }

    function withinSizeLimit() {
      return request.resource.data.keys().size() <= 30;
    }

    match /admins/{adminId} {
      allow read: if isActiveAdmin();
      allow create: if isSuperAdmin() && noDangerousFields();
      allow update: if isSuperAdmin() && noDangerousFields();
      allow delete: if false;
    }

    match /adminInvitations/{invitationId} {
      allow read: if isActiveAdmin();
      allow create, update, delete: if false;
    }

    match /adminActivityLogs/{logId} {
      allow read: if isActiveAdmin();
      allow create, update, delete: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /adminSettings/{settingId} {
      allow read: if true;
      allow create, update: if isActiveAdmin() && noDangerousFields() && withinSizeLimit();
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId || isActiveAdmin());
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && noDangerousFields()
        && withinSizeLimit();
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && noDangerousFields()
        && withinSizeLimit();
      allow delete: if false;
    }

    match /websiteContent/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /socialLinks/{linkId} {
      allow read: if true;
      allow create, update: if isActiveAdmin() && noDangerousFields() && withinSizeLimit();
      allow delete: if isActiveAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isActiveAdmin() && noDangerousFields() && withinSizeLimit();
      allow delete: if isActiveAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isActiveAdmin() && noDangerousFields() && withinSizeLimit();
      allow delete: if isActiveAdmin();
    }

    match /processSteps/{stepId} {
      allow read: if true;
      allow create, update: if isActiveAdmin() && noDangerousFields() && withinSizeLimit();
      allow delete: if isActiveAdmin();
    }

    match /portfolioProjects/{portfolioId} {
      allow read: if true;
      allow create, update: if isActiveAdmin() && noDangerousFields() && withinSizeLimit();
      allow delete: if isActiveAdmin();
    }

    match /portfolio/{portfolioId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /projectInquiries/{inquiryId} {
      allow create: if withinSizeLimit() && noDangerousFields();
      allow read: if isActiveAdmin();
      allow update: if isActiveAdmin()
        && onlyFields(['status', 'adminNotes', 'updatedAt', 'resolvedAt', 'assignedTo'])
        && withinSizeLimit();
      allow delete: if false;
    }

    match /consultationRequests/{consultationId} {
      allow create: if withinSizeLimit() && noDangerousFields();
      allow read: if isActiveAdmin();
      allow update: if isActiveAdmin()
        && onlyFields(['status', 'adminNotes', 'updatedAt', 'resolvedAt', 'assignedTo', 'scheduledAt'])
        && withinSizeLimit();
      allow delete: if false;
    }

    match /generalQueries/{queryId} {
      allow create: if withinSizeLimit() && noDangerousFields();
      allow read: if isActiveAdmin();
      allow update: if isActiveAdmin()
        && onlyFields(['status', 'adminNotes', 'updatedAt', 'resolvedAt', 'reply', 'repliedAt'])
        && withinSizeLimit();
      allow delete: if false;
    }

    match /emailCommunications/{commId} {
      allow read: if isActiveAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}