rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to verify Admin privilege (Case-insensitive & Flexible)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'Codewithsushil7236@gmail.com' ||
        request.auth.token.email == 'codewithsushil7236@gmail.com' ||
        request.auth.token.email.matches('(?i)^codewithsushil7236@gmail\\.com$') ||
        request.auth.token.email.matches('(?i)^.*admin.*$')
      );
    }

    // Helper function to check if request is from an authenticated user or admin
    function isAuth() {
      return request.auth != null || isAdmin();
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read, write: if true;
    }

    // Registered Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Public Website Content Collections (Read by all, Write allowed)
    match /websiteContent/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if true;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    match /processSteps/{stepId} {
      allow read: if true;
      allow write: if true;
    }

    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if true;
    }

    match /portfolioProjects/{portfolioId} {
      allow read: if true;
      allow write: if true;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    match /adminSettings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    // Business Leads & Inquiries
    match /projectInquiries/{inquiryId} {
      allow read, create, update, delete: if true;
    }

    match /consultationRequests/{consultationId} {
      allow read, create, update, delete: if true;
    }

    match /generalQueries/{queryId} {
      allow read, create, update, delete: if true;
    }

    // Email Communication Records & Logs
    match /emailCommunications/{commId} {
      allow read, write: if true;
    }

    // Internal Security Collections
    match /adminOtpChallenges/{challengeId} {
      allow read, write: if true;
    }

    match /adminOtps/{otpId} {
      allow read, write: if true;
    }

    match /adminAuditLogs/{logId} {
      allow read, write: if true;
    }
  }
}
