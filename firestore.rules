rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────────────────

    // Authenticated Firebase user with verified admin custom claim
    function isFirebaseAdmin() {
      return request.auth != null &&
             request.auth.token.admin == true;
    }

    // Authenticated user (any Firebase auth)
    function isAuthenticated() {
      return request.auth != null;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // ADMIN SECURITY COLLECTIONS — NO PUBLIC ACCESS
    // All access is mediated by Firebase Admin SDK (server-side only)
    // ─────────────────────────────────────────────────────────────────────────

    // Admin identities — no direct client read/write
    match /admins/{adminId} {
      allow read, write: if false;
    }

    // Admin invitations — no direct client access
    match /adminInvitations/{invitationId} {
      allow read, write: if false;
    }

    // OTP challenges — no direct client access (server-side only)
    match /adminOtpChallenges/{challengeId} {
      allow read, write: if false;
    }

    // Admin activity audit logs — no direct client access
    match /adminActivityLogs/{logId} {
      allow read, write: if false;
    }

    // Legacy audit log collection name — also locked
    match /adminAuditLogs/{logId} {
      allow read, write: if false;
    }

    // Legacy OTP collection — locked
    match /adminOtps/{otpId} {
      allow read, write: if false;
    }

    // Admin settings — locked
    match /adminSettings/{settingId} {
      allow read: if isFirebaseAdmin();
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // REGISTERED USERS COLLECTION
    // ─────────────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Users can read/write their own document
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      // Admins can read all user documents (via client SDK with claims)
      allow read: if isFirebaseAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // PUBLIC WEBSITE CONTENT — Readable by all, write via admin server only
    // ─────────────────────────────────────────────────────────────────────────

    match /websiteContent/{docId} {
      allow read: if true;
      allow write: if false;  // Server-side Admin SDK only
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /processSteps/{stepId} {
      allow read: if true;
      allow write: if false;
    }

    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if false;
    }

    match /portfolioProjects/{portfolioId} {
      allow read: if true;
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BUSINESS LEADS & INQUIRIES
    // Public can create (contact forms), admins can manage via server SDK
    // ─────────────────────────────────────────────────────────────────────────

    match /projectInquiries/{inquiryId} {
      allow create: if true;      // Anyone can submit a project inquiry
      allow read, update, delete: if false;  // Admin access via server SDK only
    }

    match /consultationRequests/{consultationId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /generalQueries/{queryId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // EMAIL COMMUNICATION RECORDS
    // ─────────────────────────────────────────────────────────────────────────

    match /emailCommunications/{commId} {
      allow read, write: if false;  // Server-side Admin SDK only
    }
  }
}
